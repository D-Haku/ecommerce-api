{
  "name": "ecommerce-api",
  "version": "0.1.0",
  "private": true,
  "description": "E-commerce API ingesting DummyJSON products into MySQL and Elasticsearch.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/api/server.js",
    "start:ingest": "node dist/ingest/index.js",
    "dev:api": "tsx src/api/server.ts",
    "dev:ingest": "tsx src/ingest/index.ts",
    "test": "vitest",
    "test:property": "vitest run test/property",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.14.0",
    "fastify": "^4.28.1",
    "mysql2": "^3.11.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/supertest": "^6.0.2",
    "fast-check": "^3.20.0",
    "msw": "^2.3.5",
    "supertest": "^7.0.0",
    "testcontainers": "^10.11.0",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
